---
import { getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import SlidingText from '../components/SlidingText.astro';
import SmoothieMenu from '../components/SmoothieMenu.astro';
import YogurtMenu from '../components/YogurtMenu.astro';
import About from '../components/About.astro';
import Gallery from '../components/Gallery.astro';
import Values from '../components/Values.astro';
import Location from '../components/Location.astro';
import Footer from '../components/Footer.astro';
import heroImage from '../assets/images/hero.jpg';

const heroOptimized = await getImage({ src: heroImage, width: 1920, height: 1080 });
---

<Layout>
  <Fragment slot="head">
    <link rel="preload" href={heroOptimized.src} as="image" />
  </Fragment>
  <Nav />
  <main>
    <Hero heroImage={heroImage} />
    <Marquee />
    <About />
    <SlidingText />
    <SmoothieMenu />
    <YogurtMenu />
    <Gallery />
    <Values />
    <Location />
    <Footer />
  </main>
</Layout>
