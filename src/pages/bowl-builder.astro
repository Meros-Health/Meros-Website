---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import BowlBuilder from '../components/BowlBuilder/BowlBuilder';
---

<Layout title="Bowl Builder — MEROS">
  <Nav />
  <main class="bowl-builder-page">
    <BowlBuilder client:load />
  </main>
</Layout>

<style>
  .bowl-builder-page {
    min-height: 100vh;
    padding-top: 6rem;
    background-color: var(--color-bg);
  }
</style>
