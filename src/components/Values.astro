---
const values = [
  {
    number: '01',
    title: 'Organic, Fresh Ingredients',
    subtitle: 'Sourced from trusted suppliers. No preservatives, no shortcuts — just real food at its peak.',
  },
  {
    number: '02',
    title: 'Handcrafted with care',
    subtitle: 'Cultured in-house, toasted daily, blended to order. Slow food made with intention.',
  },
  {
    number: '03',
    title: "A day's nourishment",
    subtitle: "Designed to fuel your morning run, afternoon focus, and evening wind-down.",
  },
  {
    number: '04',
    title: 'Wellness food',
    subtitle: 'Macros, gut health, sustained energy. We serve how you want to feel.',
  },
];
---

<section class="values" id="values">
  <div class="values__inner">
    <!-- Left: Stacked card images (hand-held effect) -->
    <div class="values__cards-wrap">
      <div class="values__cards">
        <div class="values__card values__card--back">
          <img src="/Yogurt/Hands3.jpg" alt="Hands preparing a fresh yogurt bowl with organic toppings." width="520" height="340" loading="lazy" />
        </div>
        <div class="values__card values__card--front">
          <img src="/Yogurt/Background5.jpg" alt="Bright cafe environment showcasing wellness at Meros." width="520" height="340" loading="lazy" />
        </div>
      </div>
    </div>

    <!-- Right: Numbered values list -->
    <div class="values__list">
      <p class="values__eyebrow">Our Promise</p>
      <h2 class="values__headline">What we<br />stand for</h2>
      <div class="values__divider"></div>
      <ul class="values__items">
        {values.map((v, i) => (
          <li class="values__item" style={`--i: ${i}`}>
            <span class="values__num">{v.number}</span>
            <div class="values__content">
              <h3 class="values__title">{v.title}</h3>
              <p class="values__subtitle">{v.subtitle}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .values {
    position: relative;
    z-index: 5;
    background: var(--color-bg);
    margin-top: -20px;
    padding: var(--space-32) var(--space-6);
    box-shadow: 0 -10px 36px rgba(0, 0, 0, 0.06);
  }

  .values__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 8vw, 7rem);
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Cards container: padding gives room so cards + box-shadow aren't cut off ── */
  .values__cards-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    padding: clamp(3rem, 10vw, 5.5rem); /* buffer for rotated cards + shadow blur */
    overflow: hidden; /* clip only beyond padded area, not the cards themselves */
  }

  .values__cards {
    position: relative;
    width: 100%;
    max-width: min(100%, 420px);
    aspect-ratio: 4 / 3.2;
    max-height: min(440px, 45vh); /* scale down on short viewports */
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: default;
  }

  .values__card {
    position: absolute;
    /* Scale with container: smaller on narrow viewports */
    width: clamp(160px, min(72%, 320px), 320px);
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 20px 50px rgba(28, 46, 30, 0.12),
      0 4px 16px rgba(28, 46, 30, 0.06);
    transition:
      transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      box-shadow 0.5s ease;
  }

  /* Back card — tilted left, slightly higher, behind */
  .values__card--back {
    transform: translate(-18%, -12%) rotate(-8deg) scale(0.90);
    z-index: 0;
  }

  /* Front card — tilted right, slightly lower, in front */
  .values__card--front {
    transform: translate(12%, 8%) rotate(5deg) scale(0.96);
    z-index: 1;
  }

  /* Hover: scale and transform only (no scroll/parallax) */
  .values__cards:hover .values__card--back {
    transform: translate(-20%, -10%) rotate(-10deg) scale(0.93);
    box-shadow:
      0 28px 56px rgba(28, 46, 30, 0.15),
      0 8px 22px rgba(28, 46, 30, 0.08);
  }

  .values__cards:hover .values__card--front {
    transform: translate(14%, 6%) rotate(3deg) scale(1.02);
    box-shadow:
      0 32px 64px rgba(28, 46, 30, 0.18),
      0 10px 28px rgba(28, 46, 30, 0.1);
  }

  .values__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .values__cards:hover .values__card img {
    transform: scale(1.03);
  }

  /* ── Values list ── */
  .values__list {
    display: flex;
    flex-direction: column;
    min-width: 0; /* prevent grid overflow */
  }

  .values__eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-accent);
    margin: 0 0 var(--space-4);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .values.in-view .values__eyebrow {
    opacity: 1;
    transform: translateY(0);
  }

  .values__headline {
    font-family: var(--font-serif);
    font-weight: var(--weight-light);
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin: 0;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s ease 0.1s, transform 0.6s ease 0.1s;
  }

  .values.in-view .values__headline {
    opacity: 1;
    transform: translateY(0);
  }

  .values__divider {
    width: 40px;
    height: 1px;
    background: var(--color-accent);
    margin: var(--space-6) 0;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.2s;
  }

  .values.in-view .values__divider {
    transform: scaleX(1);
  }

  .values__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .values__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-4);
    border-radius: 10px;
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease,
      background-color 0.3s ease;
    transition-delay: calc(0.25s + var(--i, 0) * 0.1s);
  }

  .values.in-view .values__item {
    opacity: 1;
    transform: translateY(0);
  }

  .values__item:hover {
    background: rgba(28, 46, 30, 0.03);
  }

  .values__num {
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--weight-regular);
    color: var(--color-accent);
    padding-top: 2px;
    letter-spacing: 0.04em;
    transition: transform 0.3s ease;
  }

  .values__item:hover .values__num {
    transform: translateX(-2px);
  }

  .values__content {
    flex: 1;
  }

  .values__title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    margin: 0 0 var(--space-1);
    letter-spacing: 0.02em;
    transition: color 0.3s ease;
  }

  .values__item:hover .values__title {
    color: var(--color-accent);
  }

  .values__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-light);
    line-height: 1.55;
    color: var(--color-text);
    opacity: 0.55;
    margin: 0;
    transition: opacity 0.3s ease;
  }

  .values__item:hover .values__subtitle {
    opacity: 0.75;
  }

  /* ── Tablet ── */
  @media (max-width: 900px) {
    .values {
      padding: var(--space-24) var(--space-6);
    }

    .values__inner {
      gap: clamp(2rem, 6vw, 4rem);
    }

    .values__cards {
      max-height: min(360px, 42vh);
    }

    .values__card {
      width: clamp(140px, min(68%, 280px), 280px);
    }

    /* Tighter offsets so cards stay on-screen */
    .values__card--back {
      transform: translate(-14%, -10%) rotate(-6deg) scale(0.90);
    }

    .values__card--front {
      transform: translate(10%, 6%) rotate(4deg) scale(0.96);
    }

    .values__cards:hover .values__card--back {
      transform: translate(-16%, -8%) rotate(-8deg) scale(0.92);
    }

    .values__cards:hover .values__card--front {
      transform: translate(12%, 4%) rotate(2deg) scale(1.01);
    }
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .values {
      padding: var(--space-24) var(--space-4);
    }

    .values__inner {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }

    .values__cards-wrap {
      order: -1;
    }

    .values__cards {
      max-height: min(300px, 38vh);
      max-width: 100%;
    }

    .values__card {
      width: clamp(140px, min(62%, 260px), 260px);
    }

    /* Reduced spread so cards fit in single column */
    .values__card--back {
      transform: translate(-12%, -8%) rotate(-5deg) scale(0.88);
    }

    .values__card--front {
      transform: translate(8%, 5%) rotate(3deg) scale(0.94);
    }

    .values__cards:hover .values__card--back {
      transform: translate(-14%, -6%) rotate(-6deg) scale(0.90);
    }

    .values__cards:hover .values__card--front {
      transform: translate(10%, 4%) rotate(2deg) scale(0.99);
    }

    .values__headline {
      font-size: clamp(1.8rem, 6vw, 2.4rem);
    }

    .values__list {
      align-items: center;
      text-align: center;
    }

    .values__divider {
      transform-origin: center;
    }

    .values__item {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: var(--space-2);
      padding: var(--space-4) var(--space-2);
    }

    .values__item:hover .values__num {
      transform: translateX(0) scale(1.1);
    }
  }

  @media (max-width: 480px) {
    .values {
      padding: var(--space-16) var(--space-4);
    }

    .values__cards {
      max-height: min(260px, 35vh);
    }

    .values__card {
      width: clamp(130px, min(58%, 220px), 220px);
    }

    .values__card--back {
      transform: translate(-10%, -6%) rotate(-4deg) scale(0.86);
    }

    .values__card--front {
      transform: translate(6%, 4%) rotate(2deg) scale(0.92);
    }

    .values__cards:hover .values__card--back {
      transform: translate(-12%, -4%) rotate(-5deg) scale(0.88);
    }

    .values__cards:hover .values__card--front {
      transform: translate(8%, 3%) rotate(1deg) scale(0.97);
    }

    .values__items {
      gap: var(--space-4);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('.values');
    if (!section) return;

    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            section.classList.add('in-view');
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );

    obs.observe(section);
  });
</script>
