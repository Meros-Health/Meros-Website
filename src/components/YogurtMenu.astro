---
import YogurtBowlName from './YogurtBowlName';

const bowls = [
  { name: 'The Moment', image: '/Yogurt/Bowl1.jpg',   descriptor: 'Blueberries, strawberries, banana, passionfruit preserve, house granola, toasted almonds, chia seeds, toasted coconut.' },
  { name: 'The Bloom',  image: '/Yogurt/Bowl3a.jpg',  descriptor: 'Mango, pineapple, bee pollen, goji berries, shredded coconut, sunflower seeds, raw honey drizzle.' },
  { name: 'The Silk',   image: '/Yogurt/Bowl5a.jpg',  descriptor: 'Raw cocoa powder, banana, strawberries, peanut butter mousse, cacao nibs, hemp hearts, maple syrup, flax meal.' },
  { name: 'The Tropic', image: '/Yogurt/Bowl7a.jpg',  descriptor: 'Mango, pineapple, papaya, toasted coconut, cashews, passionfruit preserve, chia seeds.' },
  { name: 'The Bounty', image: '/Yogurt/Bowl4c.jpg',  descriptor: 'Mashed avocado, banana, house granola, walnuts, hemp hearts, pumpkin seeds, nutritional yeast, EVOO drizzle, raw honey, flaky salt.' },
  { name: 'The Crunch', image: '/Yogurt/Bowl6b.jpg',  descriptor: 'Banana, house granola, almonds, pistachios, walnuts, hemp hearts, pumpkin seeds, chia seeds, raw honey drizzle.' },
];
---

<section class="yogurt" id="yogurt">
  <header class="yogurt__header">
    <p class="yogurt__eyebrow" data-reveal="fade">— Yoghurt Bowls —</p>
    <h2 class="yogurt__title" data-reveal="clip">Crafted to Nourish</h2>
    <p class="yogurt__subtitle" data-reveal="up" data-reveal-delay="0.15">Six bowls. Each one packed with your nutrients.</p>
  </header>

  <div class="yogurt__grid">
    {bowls.map((bowl, i) => (
      <article class="yogurt__card" data-yogurt-card>
        <div class="yogurt__card-image" data-yogurt-image>
          <img src={bowl.image} alt={bowl.name} width="600" height="600" loading="lazy" />
        </div>
        <div class="yogurt__card-content">
          <YogurtBowlName client:visible name={bowl.name} delay={i * 0.06} />
          <p class="yogurt__card-descriptor">{bowl.descriptor}</p>
        </div>
      </article>
    ))}
  </div>

  <div class="yogurt__cta-wrapper" data-reveal="up" data-reveal-delay="0.2">
    <a href="/bowl-builder" class="yogurt__cta">
      <span class="yogurt__cta-text">Build Your Own Bowl</span>
      <span class="yogurt__cta-arrow" aria-hidden="true">→</span>
    </a>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initYogurtReveal() {
    const images = document.querySelectorAll('[data-yogurt-image]');
    if (!images.length) return;

    images.forEach((img, i) => {
      gsap.set(img, { opacity: 0 });
      ScrollTrigger.create({
        trigger: img,
        start: 'top 88%',
        once: true,
        onEnter: () => {
          gsap.to(img, {
            opacity: 1,
            duration: 1.2,
            delay: (i % 3) * 0.12,
            ease: 'power2.out',
          });
        },
      });
    });
  }

  function initCtaReveal() {
    const cta = document.querySelector('.yogurt__cta-wrapper');
    if (!cta) return;

    gsap.set(cta, { opacity: 0, y: 30 });
    ScrollTrigger.create({
      trigger: cta,
      start: 'top 90%',
      once: true,
      onEnter: () => {
        gsap.to(cta, {
          opacity: 1,
          y: 0,
          duration: 0.9,
          ease: 'power2.out',
        });
      },
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initYogurtReveal();
      initCtaReveal();
    });
  } else {
    initYogurtReveal();
    initCtaReveal();
  }
</script>

<style>
  .yogurt {
    position: relative;
    z-index: 3;
    background: var(--color-bg);
    padding: var(--space-24) var(--space-6);
    margin-top: -20px;
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.1);
  }

  .yogurt__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto var(--space-16);
  }

  .yogurt__eyebrow {
    font-family: var(--font-body);
    font-weight: var(--weight-thin);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .yogurt__title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: italic;
    font-size: var(--text-4xl);
    color: var(--color-text);
    margin-bottom: var(--space-4);
    line-height: var(--leading-tight);
  }

  .yogurt__subtitle {
    font-family: var(--font-body);
    font-weight: var(--weight-thin);
    font-size: var(--text-base);
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
  }

  .yogurt__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 900px) {
    .yogurt__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .yogurt__grid {
      grid-template-columns: 1fr;
    }

    .yogurt__title {
      font-size: var(--text-2xl);
    }
  }

  .yogurt__card {
    display: flex;
    flex-direction: column;
  }

  .yogurt__card-image {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--radius-md);
    margin-bottom: var(--space-4);
  }

  .yogurt__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease-elegant);
  }

  .yogurt__card:hover .yogurt__card-image img {
    transform: scale(1.03);
  }

  .yogurt__card-content {
    padding: 0 var(--space-1);
  }

  /* Scoped styles applied to the framer-motion <h3> via :global() */
  :global(.yogurt__card-name) {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: var(--text-lg);
    color: var(--color-text);
    margin-bottom: var(--space-2);
    padding-bottom: var(--space-2);
    border-bottom: var(--border-accent);
    line-height: var(--leading-snug);
  }

  .yogurt__card-descriptor {
    font-family: var(--font-body);
    font-weight: var(--weight-light);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin-top: var(--space-2);
  }

  /* ── CTA Button ────────────────────────────────────────────────────────────── */
  .yogurt__cta-wrapper {
    display: flex;
    justify-content: center;
    margin-top: var(--space-16);
    padding-bottom: var(--space-4);
  }

  .yogurt__cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--space-3, 0.75rem);
    padding: 1rem 2.5rem;
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--text-sm);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text);
    border: 1px solid var(--color-text);
    border-radius: 0;
    background: transparent;
    cursor: pointer;
    text-decoration: none;
    overflow: hidden;
    transition: color 0.4s ease, border-color 0.4s ease;
  }

  /* Slide-in background fill */
  .yogurt__cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-text, #1c2e1e);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.45s cubic-bezier(0.25, 0.1, 0.25, 1);
    z-index: 0;
  }

  .yogurt__cta:hover::before {
    transform: scaleX(1);
  }

  .yogurt__cta:hover {
    color: var(--color-bg, #fafaf7);
    border-color: var(--color-text);
  }

  .yogurt__cta-text,
  .yogurt__cta-arrow {
    position: relative;
    z-index: 1;
  }

  /* Arrow nudge on hover */
  .yogurt__cta-arrow {
    display: inline-block;
    transition: transform 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .yogurt__cta:hover .yogurt__cta-arrow {
    transform: translateX(5px);
  }

  /* Subtle pulse animation when idle */
  @keyframes cta-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(28, 46, 30, 0); }
    50% { box-shadow: 0 0 0 6px rgba(28, 46, 30, 0.06); }
  }

  .yogurt__cta {
    animation: cta-glow 3s ease-in-out infinite;
  }

  .yogurt__cta:hover {
    animation: none;
  }
</style>
