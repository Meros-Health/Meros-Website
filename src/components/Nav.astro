---
import NavBar from './NavBar';
---

<NavBar client:load />

<style>
  /* ── Safe-area fill — covers the notch/status-bar zone ────────────────────── */
  :global(.nav-safe-fill) {
    display: none;
  }

  /* ── Nav shell ─────────────────────────────────────────────────────────────── */
  :global(.nav) {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    display: flex;
    align-items: center;
    justify-content: space-between;
    /* Solid white — no blur, no transparency */
    background: #FAFAF7;
    border-bottom: 1px solid rgba(28, 46, 30, 0.1);
    /* Top padding absorbs the notch on iPhone */
    padding: var(--space-4) var(--space-6);
    padding-top: calc(var(--space-4) + env(safe-area-inset-top, 0px));
  }

  /* ── Logo ──────────────────────────────────────────────────────────────────── */
  :global(.nav__logo) {
    flex-shrink: 0;
    font-family: var(--font-serif);
    font-weight: var(--weight-light);
    font-size: 1.375rem;
    letter-spacing: 0.3em;
    color: var(--color-text);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  :global(.nav__logo:hover) {
    opacity: 0.65;
  }

  /* ── Desktop links ─────────────────────────────────────────────────────────── */
  :global(.nav__links) {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  :global(.nav__link) {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  :global(.nav__link:hover) {
    opacity: 0.55;
  }

  /* BUILD pill — black bg, white text */
  :global(.nav__link--build) {
    background: #111;
    color: #FAFAF7;
    padding: 6px 16px;
    border-radius: 999px;
    transition: background var(--transition-fast), opacity var(--transition-fast);
  }

  :global(.nav__link--build:hover) {
    background: #2a2a2a;
    opacity: 1;
  }

  /* ── Hamburger — hidden on desktop ────────────────────────────────────────── */
  :global(.nav__hamburger) {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    /* 44×44 tap target */
    padding: 11px 10px;
    color: var(--color-text);
  }

  :global(.nav__bar) {
    display: block;
    width: 22px;
    height: 1.5px;
    background: currentColor;
    transform-origin: center;
  }

  /* ── Mobile backdrop — hidden until menu open ──────────────────────────────── */
  :global(.nav__mobile-backdrop) {
    display: none;
  }

  /* ── Mobile menu — hidden on desktop ──────────────────────────────────────── */
  :global(.nav__mobile-menu) {
    display: none;
  }

  /* ── Mobile breakpoint ─────────────────────────────────────────────────────── */
  @media (max-width: 860px) {
    :global(.nav__links) {
      display: none;
    }

    :global(.nav__hamburger) {
      display: flex;
    }

    :global(.nav__mobile-backdrop) {
      display: block;
      position: fixed;
      inset: 0;
      z-index: calc(var(--z-nav) - 2);
      background: transparent;
      border: 0;
      padding: 0;
      margin: 0;
      cursor: default;
    }

    :global(.nav__mobile-menu) {
      display: flex;
      position: fixed;
      /* Sits flush below the nav — nav height = padding-top (safe-area + 1rem) + content (~22px) + padding-bottom (1rem) */
      top: calc(3.375rem + env(safe-area-inset-top, 0px));
      left: 0;
      right: 0;
      z-index: calc(var(--z-nav) - 1);
      background: #FAFAF7;
      border-bottom: 1px solid rgba(28, 46, 30, 0.1);
      flex-direction: column;
      align-items: center;
      padding: var(--space-6) var(--space-6) var(--space-8);
      gap: var(--space-6);
    }

    :global(.nav__mobile-link) {
      font-family: var(--font-body);
      font-weight: var(--weight-regular);
      font-size: var(--text-sm);
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-text);
      text-decoration: none;
      /* Full-width tap target */
      min-height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      transition: opacity var(--transition-fast);
    }

    :global(.nav__mobile-link:hover) {
      opacity: 0.55;
    }

    /* BUILD pill in mobile menu — larger, draws more attention */
    :global(.nav__mobile-link--build) {
      background: #111;
      color: #FAFAF7;
      padding: 10px 32px;
      border-radius: 999px;
      width: auto;
      min-width: 160px;
      transition: background var(--transition-fast);
    }

    :global(.nav__mobile-link--build:hover) {
      background: #2a2a2a;
      opacity: 1;
    }
  }
</style>
