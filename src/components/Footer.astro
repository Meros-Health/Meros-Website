---
---

<footer class="footer">
  <p class="footer__wordmark">MEROS</p>
  <p class="footer__tagline">Pure. Simple. Intentional.</p>
  <p class="footer__copy">© {new Date().getFullYear()} Meros. All rights reserved.</p>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 7;
    background: var(--color-bg-dark);
    padding: var(--space-16) var(--space-6);
    text-align: center;
    margin-top: -20px;
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.32);
  }

  .footer__wordmark {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 3rem;
    letter-spacing: 0.4em;
    text-indent: 0.4em;
    text-transform: uppercase;
    color: var(--color-text-light);
    opacity: 0.4;
    margin-bottom: var(--space-4);
  }

  .footer__tagline {
    font-family: var(--font-body);
    font-weight: var(--weight-thin);
    font-size: var(--text-xs);
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--color-text-light);
    opacity: 0.6;
    margin-bottom: var(--space-8);
  }

  .footer__copy {
    font-family: var(--font-body);
    font-weight: var(--weight-thin);
    font-size: var(--text-xs);
    color: var(--color-text-light);
    opacity: 0.5;
  }
</style>
