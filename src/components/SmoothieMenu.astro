---
const smoothies = [
  { name: 'Cacao Revival', image: '/Smoothies-Menu/Smoothie1b.jpg', descriptor: 'Rich cacao with nut butter and banana.' },
  { name: 'Berry Ritual', image: '/Smoothies-Menu/Smoothie3b.jpg', descriptor: 'Mixed berries with a touch of vanilla.' },
  { name: 'Green Clarity', image: '/Smoothies-Menu/Smoothie4b.jpg', descriptor: 'Kale, spinach, apple, and lime.' },
  { name: 'Tropical Reset', image: '/Smoothies-Menu/Smoothie5b.jpg', descriptor: 'Pineapple, coconut, and passion fruit.' },
  { name: 'Dark Bloom', image: '/Smoothies-Menu/Smoothie6b.jpg', descriptor: 'Beet, berry, and dark cherry.' },
  { name: 'Golden Hour', image: '/Smoothies-Menu/Smoothie2b.jpg', descriptor: 'Turmeric, mango, and ginger glow.' },
];
---

<section class="menu" id="menu">
  <div class="menu__blob" data-parallax-blob aria-hidden="true"></div>
  <header class="menu__header">
    <h2 class="menu__title" data-reveal="clip">Made to Heal</h2>
    <p class="menu__subtitle" data-reveal="up" data-reveal-delay="0.15">Homemade smoothies created with fresh, authentic ingredients.</p>
  </header>
  <div class="menu__pin">
    <div class="menu__track">
      {smoothies.map((s) => (
        <article class="menu__card">
          <div class="menu__card-image">
            <img src={s.image} alt={s.name} width="600" height="800" />
          </div>
          <div class="menu__card-content">
            <h3 class="menu__card-name">{s.name}</h3>
            <p class="menu__card-descriptor">{s.descriptor}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function buildScrollTrigger(track: HTMLElement, cards: NodeListOf<Element>, edgePad: number, scrubValue: number) {
    const navHeight = (document.querySelector('.nav') as HTMLElement)?.offsetHeight ?? 56;
    
    // Calculate scroll distance proportionally to content width vs viewport
    const getScrollDistance = () => {
      const contentWidth = track.scrollWidth;
      const viewportWidth = window.innerWidth;
      // How many "screens" worth of content we have
      const screensOfContent = contentWidth / viewportWidth;
      // Scale scroll distance proportionally - more content = more scroll needed
      return Math.max(viewportWidth * screensOfContent * 0.8, viewportWidth);
    };

    ScrollTrigger.create({
      trigger: '.menu',
      start: `top top+=${navHeight}`,
      end: () => `+=${getScrollDistance()}`,
      pin: '.menu',
      scrub: scrubValue,
      invalidateOnRefresh: true,
      onUpdate: (self) => {
        const progress = self.progress;
        const currentWidth = track.scrollWidth;
        const maxX = Math.max(0, currentWidth - window.innerWidth + edgePad);
        gsap.set(track, { x: -progress * maxX });
        cards.forEach((card) => {
          const rect = card.getBoundingClientRect();
          const center = rect.left + rect.width / 2;
          const viewportCenter = window.innerWidth / 2;
          const distance = Math.abs(center - viewportCenter);
          const scale = Math.max(0.96, 1 - (distance / window.innerWidth) * 0.04);
          gsap.set(card, { scale });
        });
      },
    });
  }

  function initSmoothieMenuScroll() {
    const track = document.querySelector('.menu__track') as HTMLElement | null;
    const cards = document.querySelectorAll('.menu__card');
    if (!track || !cards.length) return;

    ScrollTrigger.matchMedia({
      // Desktop: smooth scrub
      '(min-width: 1025px)': function () {
        buildScrollTrigger(track, cards, 48, 1.2);
      },
      
      // Tablet: slightly slower scrub for more control
      '(min-width: 769px) and (max-width: 1024px)': function () {
        buildScrollTrigger(track, cards, 32, 1.5);
      },

      // Mobile: slower scrub for fine control on touch
      '(max-width: 768px)': function () {
        buildScrollTrigger(track, cards, 24, 2);
      },
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSmoothieMenuScroll);
  } else {
    initSmoothieMenuScroll();
  }
</script>

<style>
  .menu {
    position: relative;
    z-index: 4;
    background: var(--color-bg-dark);
    margin-top: -20px;
    /* Full viewport height */
    height: 100svh;
    min-height: 100svh;
    max-height: 100svh;
    display: flex;
    flex-direction: column;
    box-shadow: 0 -20px 60px rgba(0, 0, 0, 0.45), 0 -1px 0 rgba(0, 0, 0, 0.12);
    overflow: hidden;
  }

  .menu__blob {
    position: absolute;
    inset: -20% 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(ellipse 55% 40% at 15% 40%, rgba(201, 106, 74, 0.08) 0%, transparent 70%),
      radial-gradient(ellipse 40% 35% at 80% 65%, rgba(123, 79, 191, 0.06) 0%, transparent 70%);
    will-change: transform;
  }

  .menu__header {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--space-12) var(--space-6) var(--space-6);
    flex-shrink: 0;
  }

  .menu__title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: italic;
    font-size: var(--text-3xl);
    color: var(--color-text-light);
  }

  .menu__subtitle {
    font-family: var(--font-body);
    font-weight: var(--weight-thin);
    font-size: var(--text-base);
    letter-spacing: 0.2em;
    color: rgba(250, 250, 247, 0.5);
  }

  .menu__pin {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-bottom: var(--space-8);
  }

  .menu__track {
    display: flex;
    gap: 24px; /* Consistent gap across all screen sizes */
    padding-left: var(--space-6);
    padding-right: var(--space-6);
    will-change: transform;
    align-items: stretch;
  }

  .menu__card {
    flex-shrink: 0;
    /* Card width scales with viewport, maintaining proportion */
    width: clamp(220px, 22vw, 320px);
    /* Card height fills available space minus padding */
    height: calc(100svh - 220px);
    max-height: 600px;
    will-change: transform;
    background: var(--color-bg);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(28, 46, 30, 0.06);
    display: flex;
    flex-direction: column;
  }

  .menu__card-image {
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .menu__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .menu__card-content {
    padding: var(--space-4);
    flex-shrink: 0;
  }

  .menu__card-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1rem, 2vw, 1.5rem);
    color: var(--color-text);
    margin-bottom: var(--space-1);
    padding-bottom: var(--space-1);
    border-bottom: var(--border-accent);
  }

  .menu__card-descriptor {
    font-family: var(--font-body);
    font-weight: var(--weight-light);
    font-size: clamp(0.7rem, 1.2vw, 0.875rem);
    color: var(--color-text-muted);
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .menu__card {
      width: clamp(200px, 28vw, 280px);
      height: calc(100svh - 200px);
      max-height: 520px;
    }

    .menu__header {
      padding: var(--space-8) var(--space-6) var(--space-4);
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .menu__header {
      padding: var(--space-8) var(--space-4) var(--space-4);
    }

    .menu__track {
      gap: 24px; /* Same gap as desktop */
      padding-left: var(--space-4);
      padding-right: var(--space-4);
    }

    .menu__card {
      width: clamp(180px, 45vw, 260px);
      height: calc(100svh - 180px);
      max-height: 480px;
    }

    .menu__card-content {
      padding: var(--space-3);
    }

    .menu__title {
      font-size: clamp(2rem, 10vw, 4rem);
    }

    .menu__subtitle {
      font-size: var(--text-sm);
    }

    .menu__pin {
      padding-bottom: var(--space-6);
    }
  }
  
  /* Small mobile */
  @media (max-width: 480px) {
    .menu__card {
      width: clamp(160px, 55vw, 220px);
      height: calc(100svh - 160px);
      max-height: 420px;
    }
    
    .menu__track {
      gap: 24px; /* Same gap */
      padding-left: var(--space-3);
      padding-right: var(--space-3);
    }

    .menu__header {
      padding: var(--space-6) var(--space-3) var(--space-3);
    }
  }
</style>
