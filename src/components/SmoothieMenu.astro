---
import SmoothieCarousel from './SmoothieCarousel.tsx';
---

<section class="menu" id="menu">
  <div class="menu__blob" aria-hidden="true"></div>
  <header class="menu__header">
    <h2 class="menu__title" data-reveal="clip">Made to Heal</h2>
    <p class="menu__subtitle" data-reveal="up" data-reveal-delay="0.15">
      Homemade smoothies created with fresh, authentic ingredients.
    </p>
  </header>
  <div class="menu__stage">
    <SmoothieCarousel client:load />
  </div>
</section>

<style>
  .menu {
    --nav-height: 56px;
    position: relative;
    z-index: 6;
    display: flex;
    flex-direction: column;
    min-height: calc(105svh - var(--nav-height));
    background: var(--color-bg-dark);
    padding-top: clamp(var(--space-12), 8vh, var(--space-24));
    padding-bottom: clamp(var(--space-16), 10vh, var(--space-32));
    margin-top: -20px;
    box-shadow: 0 -20px 60px rgba(0, 0, 0, 0.45), 0 -1px 0 rgba(0, 0, 0, 0.12);
  }

  .menu__blob {
    position: absolute;
    inset: -20% 0;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(ellipse 55% 40% at 50% 55%, rgba(201, 106, 74, 0.1) 0%, transparent 70%);
    will-change: transform;
  }

  .menu__header {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    text-align: center;
    margin-bottom: var(--space-12);
    padding-left: var(--space-6);
    padding-right: var(--space-6);
  }

  .menu__title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(2rem, 5vh + 1.5rem, var(--text-3xl));
    color: var(--color-text-light);
  }

  .menu__subtitle {
    font-family: var(--font-body);
    font-weight: var(--weight-thin);
    font-size: clamp(var(--text-sm), 1.2vh + 0.5rem, var(--text-base));
    letter-spacing: 0.2em;
    color: rgba(250, 250, 247, 0.5);
  }

  /* Stage: holds arrows + carousel — clip prevents horizontal scroll from off-screen cards */
  .menu__stage {
    position: relative;
    z-index: 1;
    flex: 1;
    min-height: 0;
    width: 100%;
    overflow-x: clip;
    overflow-y: visible;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Arrow buttons — :global so they apply to React-rendered elements */
  :global(.carousel-arrow) {
    z-index: 10;
    flex-shrink: 0;
    width: 44px;
    min-height: 80px;
    background: var(--color-bg-dark);
    border: 1px solid var(--color-bg-dark);
    border-radius: var(--radius-md);
    color: var(--color-text-light);
    font-family: var(--font-body);
    font-size: var(--text-base);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-fast);
  }

  :global(.carousel-arrow:hover) {
  transform: scale(1.1);
  }

  @media (max-width: 768px) {
    .menu__title {
      font-size: clamp(1.75rem, 5vh + 1rem, 3.5rem);
    }
  }

  @media (max-width: 420px) {
    .menu__title {
      font-size: clamp(1.4rem, 4vh + 0.9rem, 2.25rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global([style*="transition"]) {
      transition: none !important;
    }
  }
</style>
